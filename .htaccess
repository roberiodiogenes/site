# ================================================================
# ROBÉRIO DIÓGENES — /.htaccess
# Segurança geral, HTTPS e proteções de acesso
# ================================================================

Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ── HTTPS: descomentar após ativar SSL no Hostgator ──────────
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ── Sitemap amigável: /sitemap.xml → sitemap.php ─────────────
  RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]

  # ── Páginas inexistentes → 404.html (via _404.php) ──────────
  # Funciona em XAMPP (subpasta) e produção (raiz do domínio)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI}  !_404\.php       [NC]
  RewriteCond %{REQUEST_URI}  !manutencao\.php [NC]
  RewriteCond %{REQUEST_URI}  !/admin/         [NC]
  RewriteCond %{REQUEST_URI}  !/backend/       [NC]
  RewriteRule ^ _404.php [L]

  # ── Modo de Manutenção ────────────────────────────────────────
  # Redireciona tudo para manutencao.php quando manutencao.lock
  # existir na raiz do site.
  # A dupla condição cobre produção (DOCUMENT_ROOT = raiz do site)
  # e localhost XAMPP (DOCUMENT_ROOT = htdocs, site em subpasta).
  RewriteCond %{DOCUMENT_ROOT}/manutencao.lock                     -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/roberiodiogenes.com/manutencao.lock -f
  RewriteCond %{REQUEST_URI}  !/admin/          [NC]
  RewriteCond %{REQUEST_URI}  !/backend/        [NC]
  RewriteCond %{REQUEST_URI}  !manutencao\.php  [NC]
  RewriteCond %{REQUEST_URI}  !\.(css|js|webp|jpg|jpeg|png|gif|ico|svg|woff2?|ttf|otf)$ [NC]
  RewriteRule ^ manutencao.php [L]
</IfModule>

# ── Páginas de erro personalizadas ───────────────────────────
# IMPORTANTE: Dois ambientes, dois caminhos:
#
#   XAMPP LOCAL (site em /roberiodiogenes.com/ dentro do htdocs):
#     ErrorDocument 404 /roberiodiogenes.com/_404.php
#
#   PRODUÇÃO (HostGator — site na raiz do domínio):
#     ErrorDocument 404 /_404.php
#
# Troque as linhas comentadas abaixo conforme o ambiente.
# Obs.: se mod_rewrite estiver ativo, o RewriteRule acima já captura
# todas as páginas inexistentes e esta diretiva vira apenas fallback.
#
# Para ativar mod_rewrite no XAMPP:
# Abra C:\xampp\apache\conf\httpd.conf e descomente:
#   LoadModule rewrite_module modules/mod_rewrite.so
# Depois reinicie o Apache.
#
# ── AMBIENTE ATUAL: XAMPP local ──────────────────────────────
ErrorDocument 403 /roberiodiogenes.com/_404.php
ErrorDocument 404 /roberiodiogenes.com/_404.php
# ── PRODUÇÃO: descomente e comente as linhas acima ───────────
# ErrorDocument 403 /_404.php
# ErrorDocument 404 /_404.php

# ── Proteger arquivos sensíveis ───────────────────────────────
<FilesMatch "(config\.php|mailer\.php|\.env|\.git|composer\.(json|lock)|package(-lock)?\.json)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ── Bloquear acesso direto a arquivos de log, SQL e scripts ──
<FilesMatch "\.(log|sql|bak|backup|sh|bash)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ── Bloquear ferramentas de diagnóstico ───────────────────────
<FilesMatch "^(diagnostico|phpinfo|info|test|teste)\.php$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ── Cabeçalhos de segurança HTTP ─────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HSTS — ativar APÓS confirmar HTTPS funcionando em produção:
  # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Compressão GZIP ───────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
</IfModule>

# ── Cache de assets estáticos ─────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
